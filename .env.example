# Environment Configuration Template
# Copy this to .env and fill in actual values

# ============= JWT Configuration =============
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============= Database Configuration =============
DATABASE_URL=postgresql://aios_user:aios_password@localhost:5432/aios_database
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============= Redis Configuration =============
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ============= RabbitMQ Configuration =============
RABBITMQ_URL=amqp://admin:admin@localhost:5672/
RABBITMQ_VHOST=/

# ============= API Gateway Configuration =============
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=3600

# ============= Auth Service Configuration =============
AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=8001
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ============= Business Service Configuration =============
BUSINESS_SERVICE_HOST=0.0.0.0
BUSINESS_SERVICE_PORT=8002

# ============= Platform Integration Configuration =============
PLATFORM_INTEGRATION_HOST=0.0.0.0
PLATFORM_INTEGRATION_PORT=8003

# ============= Meta (Facebook) API Configuration =============
META_API_VERSION=v18.0
META_GRAPH_API_URL=https://graph.instagram.com
META_SDK_TIMEOUT=30

# ============= Google Ads API Configuration =============
GOOGLE_ADS_DEVELOPER_TOKEN=your-token-here
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=0987654321

# ============= TikTok Ads API Configuration =============
TIKTOK_API_BASE_URL=https://ads.tiktok.com/open_api
TIKTOK_API_TIMEOUT=30

# ============= LinkedIn Ads Configuration =============
LINKEDIN_API_BASE_URL=https://api.linkedin.com/v2
LINKEDIN_API_VERSION=v2

# ============= Shopify Configuration =============
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_TOPIC=orders/create

# ============= WooCommerce Configuration =============
WOOCOMMERCE_API_VERSION=wc/v3

# ============= ML Service Configuration =============
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8004
MODEL_UPDATE_FREQUENCY_DAYS=30
MODEL_RETRAINING_DAY_OF_MONTH=1

# ============= LLM Configuration =============
LLM_PROVIDER=openai  # openai, anthropic
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229

# ============= Logging Configuration =============
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/aios

# ============= Monitoring Configuration =============
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
SENTRY_DSN=your-sentry-dsn-here

# ============= Frontend Configuration =============
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
REACT_APP_ENV=development

# ============= Feature Flags =============
FEATURE_AUTO_MODE_ENABLED=true
FEATURE_EXPERIMENTATION_ENABLED=true
FEATURE_RISK_MANAGEMENT_ENABLED=true
MAX_AUTO_MODE_BUDGET_CHANGE_PERCENTAGE=20
MIN_ROAS_THRESHOLD=1.5
MAX_BUDGET_ALLOCATION_PER_CAMPAIGN=100000
