# Database
POSTGRES_USER=marketing_user
POSTGRES_PASSWORD=marketing_secret
POSTGRES_DB=marketing_ai_db
DATABASE_URL=postgresql+asyncpg://marketing_user:marketing_secret@db:5432/marketing_ai_db

# Redis setup (Celery)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Qdrant Vector DB
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=local_development

# JWT & Security
SECRET_KEY=yoursecretkeythatneedstobelongandsecure
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 1 day

# External APIs
OPENAI_API_KEY=sk-youropenaikey
CLAUDE_API_KEY=sk-ant-yourclaudekey
STRIPE_SECRET_KEY=sk_test_yourstripesecret
STRIPE_WEBHOOK_SECRET=whsec_yourwebhooksecret

# Feature Flags
ENVIRONMENT=development
ENABLE_LOCAL_AIRLLM=True
